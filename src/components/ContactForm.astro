---
// ─────────────────────────────────────────────────────────
// Contact Form — Clean, minimal inputs
// Supports dark and light variants.
// ─────────────────────────────────────────────────────────

interface Props {
  variant?: "dark" | "light";
}

const { variant = "dark" } = Astro.props;
const isLight = variant === "light";

const inputClasses = isLight
  ? "w-full bg-transparent border-b border-brand-black/20 py-4 text-body text-brand-black placeholder:text-brand-dark-grey focus:border-brand-black focus:outline-none transition-colors"
  : "w-full bg-transparent border-b border-brand-dark-grey/40 py-4 text-body text-brand-light-grey placeholder:text-brand-dark-grey focus:border-brand-off-white focus:outline-none transition-colors";
---

<form
  action="https://formspree.io/f/your-form-id"
  method="POST"
  class="space-y-6"
>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
      <label for="name" class="sr-only">Full Name</label>
      <input
        type="text"
        id="name"
        name="name"
        placeholder="Name"
        required
        autocomplete="name"
        class={inputClasses}
      />
    </div>
    <div>
      <label for="email" class="sr-only">Email Address</label>
      <input
        type="email"
        id="email"
        name="email"
        placeholder="Email"
        required
        autocomplete="email"
        class={inputClasses}
      />
    </div>
  </div>

  <div>
    <label for="subject" class="sr-only">Subject</label>
    <input
      type="text"
      id="subject"
      name="subject"
      placeholder="Subject"
      class={inputClasses}
    />
  </div>

  <div>
    <label for="message" class="sr-only">Message</label>
    <textarea
      id="message"
      name="message"
      placeholder="Tell me about your project..."
      required
      rows={6}
      class={`${inputClasses} resize-none`}
    ></textarea>
  </div>

  <div class="pt-4">
    <button
      type="submit"
      class:list={[
        "inline-flex items-center gap-2 px-8 py-3 text-caption uppercase font-semibold transition-colors duration-200",
        isLight
          ? "bg-brand-black text-brand-off-white hover:bg-brand-off-black"
          : "bg-brand-off-white text-brand-black hover:bg-brand-light-grey",
      ]}
    >
      Send Message
      <span aria-hidden="true">&rarr;</span>
    </button>
  </div>
</form>
